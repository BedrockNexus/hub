    "nuqs": "^2.8.9",
    "radix-ui": "^1.6.2",
    "react": "^19.2.7",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.7",
    "react-email": "^5.2.8",
    "react-hook-form": "^7.77.0",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.10.0",
    "recharts": "3.8.0",
    "remark-directive": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwind-scrollbar-hide": "^4.0.0",
    "unist-util-visit": "^5.1.0",
