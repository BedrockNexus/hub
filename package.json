    "baseline-browser-mapping": "^2.10.43",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.5",
    "eslint-config-next": "16.2.10",
    "npm-run-all2": "^8.0.4",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "ultracite": "7.0.11"
  }
