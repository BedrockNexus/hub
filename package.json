{
  "name": "@bedrocknexus/hub",
  "version": "0.1.0",
  "description": "The open-source Bedrock Nexus community platform.",
  "private": true,
  "license": "AGPL-3.0-only",
  "homepage": "https://bedrocknexus.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BedrockNexus/hub.git"
  },
  "bugs": {
    "url": "https://github.com/BedrockNexus/hub/issues"
  },
  "packageManager": "bun@1.3.6",
  "scripts": {
    "dev": "npm-run-all --parallel dev:frontend dev:backend",
    "dev:frontend": "next dev",
    "dev:backend": "convex dev",
    "predev": "convex dev --until-success && convex dashboard",
    "build": "cross-env BROWSERSLIST_IGNORE_OLD_DATA=true next build",
    "start": "next start",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "lint:framework": "eslint . --ignore-pattern \"convex/_generated/**\" --ignore-pattern \"convex/betterAuth/_generated/**\"",
    "typecheck": "tsc --noEmit",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1090.0",
    "@base-ui/react": "^1.6.0",
